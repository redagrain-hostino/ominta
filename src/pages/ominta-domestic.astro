---
import Layout from "../layouts/Layout.astro";
import WhyChooseSection from "../components/WhyChooseSection.astro";
import AboutSection from "../components/AboutSection.astro";
import FAQSection from "../components/FAQSection.astro";
import TestimonialsSection from "../components/TestimonialsSection.astro";
---

<Layout title="Ominta Domestic | Service de nettoyage à domicile à Tanger">
  <section class="dom-hero">
    <div class="dom-hero-inner">
      <!-- Left column: logo + text + reviews + CTA -->
      <div class="dom-hero-left">
        <div class="dom-hero-content">
          <!-- Ominta Domestic Logo -->
          <div class="dom-logo">
            <img
              decoding="async"
              width="500"
              height="143"
              src="/images/ominta-domestic-e1755508725634-1024x292.webp"
              alt="logo ominta domestic"
              srcset="/images/ominta-domestic-e1755508725634-1024x292.webp 1024w,
                    /images/ominta-domestic-e1755508725634-768x219.webp 768w,
                    /images/ominta-domestic-e1755508725634-300x85.webp 300w"
              sizes="(max-width:1024px) 100vw, 500px"
            />
          </div>

          <h1 class="dom-hero-title">Nettoyage à domicile à Tanger</h1>

          <p class="dom-hero-desc">
            Ominta Domestic, votre société de nettoyage à Tanger, proche de vous
            pour des services à domicile adaptés aux
            <strong>maisons</strong>, <strong>villas</strong>, <strong
              >appartements</strong
            > et <strong>résidences</strong>.
          </p>

          <div class="dom-hero-reviews">
            <img
              decoding="async"
              width="1024"
              height="229"
              src="/images/avis-nettoyage-tanger-e1755459834916-1024x229.png"
              alt="Avis Ominta Société de nettoyage à Tanger"
              srcset="/images/avis-nettoyage-tanger-e1755459834916-1024x229.png 1024w,
                    /images/avis-nettoyage-tanger-e1755459834916-768x171.png 768w,
                    /images/avis-nettoyage-tanger-e1755459834916-300x67.png 300w"
              sizes="(max-width:1024px) 100vw, 1024px"
            />
          </div>

          <div class="dom-hero-cta">
            <a href="/contact" class="dom-hero-btn">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 512 512"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M502.3 190.8c3.9-3.1 9.7-.2 9.7 4.7V400c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V195.6c0-5 5.7-7.8 9.7-4.7 22.4 17.4 52.1 39.5 154.1 113.6 21.1 15.4 56.7 47.8 92.2 47.6 35.7.3 72-32.8 92.3-47.6 102-74.1 131.6-96.3 154-113.7zM256 320c23.2.4 56.6-29.2 73.4-41.4 132.7-96.3 142.8-104.7 173.4-128.7 5.8-4.5 9.2-11.5 9.2-18.9v-19c0-26.5-21.5-48-48-48H48C21.5 64 0 85.5 0 112v19c0 7.4 3.4 14.3 9.2 18.9 30.6 23.9 40.7 32.4 173.4 128.7 16.8 12.2 50.2 41.8 73.4 41.4z"
                ></path>
              </svg>
              <span>Réserver maintenant</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Right column: background image + callback form -->
      <div class="dom-hero-right">
        <div class="dom-hero-form-wrapper">
          <div class="dom-hero-form-card">
            <p class="dom-form-label-top">RAPPEL GRATUIT ET IMMÉDIAT</p>
            <p class="dom-form-sublabel">
              Un conseiller vous appellera dans quelques instants.
            </p>

            <form class="dom-callback-form" action="#" method="post" novalidate>
              <input
                id="dom-hero-name"
                type="text"
                name="your-name"
                placeholder="Nom complet *"
                autocomplete="name"
                required
                maxlength="400"
              />
              <input
                id="dom-hero-phone"
                type="tel"
                name="phone-number"
                placeholder="Téléphone *"
                autocomplete="tel"
                required
                maxlength="400"
              />
              <button type="submit" class="dom-form-submit">Envoyer</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="dom-intro-section">
    <div class="dom-intro-inner">
      <!-- Left: Text + CTA -->
      <div class="dom-intro-text-col">
        <h2 class="dom-intro-title">Nettoyage à domicile by Ominta®</h2>
        <div class="dom-intro-desc">
          <p>
            Avec Ominta, votre maison, appartement ou villa retrouve tout son
            éclat. Nos <a
              href="https://www.ominta.ma/femme-de-menage-tanger"
              style="text-decoration: underline;">femmes de ménage Tanger</a
            > qualifiées assurent un entretien complet et soigné de vos espaces de
            vie : dépoussiérage, sols, vitres, cuisine, salles de bains… Nous adaptons
            nos prestations à votre rythme et à vos besoins pour vous offrir confort,
            propreté et sérénité au quotidien.
          </p>
          <p>
            Grâce à nos tarifs clairs, à nos solutions écologiques <strong
              >certifiées ONSSA</strong
            > et à notre disponibilité 365 jours par an, nous prenons en charge l'entretien
            de votre domicile afin que vous puissiez profiter pleinement de votre
            temps et vous concentrer sur l'essentiel.
          </p>
          <p>
            Appelez dès maintenant le <a href="tel:+212670077979"
              >(+212) 670-077-979</a
            > et confiez vos besoins de nettoyage à une société spécialisée, disponible
            et à l'écoute de vos attentes.
          </p>
        </div>
        <div class="dom-intro-cta">
          <a href="/contact" class="dom-intro-btn">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="13"
              height="13"
              viewBox="0 0 512 512"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M502.3 190.8c3.9-3.1 9.7-.2 9.7 4.7V400c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V195.6c0-5 5.7-7.8 9.7-4.7 22.4 17.4 52.1 39.5 154.1 113.6 21.1 15.4 56.7 47.8 92.2 47.6 35.7.3 72-32.8 92.3-47.6 102-74.1 131.6-96.3 154-113.7zM256 320c23.2.4 56.6-29.2 73.4-41.4 132.7-96.3 142.8-104.7 173.4-128.7 5.8-4.5 9.2-11.5 9.2-18.9v-19c0-26.5-21.5-48-48-48H48C21.5 64 0 85.5 0 112v19c0 7.4 3.4 14.3 9.2 18.9 30.6 23.9 40.7 32.4 173.4 128.7 16.8 12.2 50.2 41.8 73.4 41.4z"
              ></path>
            </svg>
            <span>Réserver maintenant</span>
          </a>
        </div>
      </div>
      <div class="dom-intro-image-col">
        <img
          loading="lazy"
          decoding="async"
          width="1024"
          height="957"
          src="/images/societe-nettoyage-tanger-1024x957.jpg"
          alt="Société de Nettoyage disponible à Tanger"
          srcset="/images/societe-nettoyage-tanger-1024x957.jpg 1024w,
                /images/societe-nettoyage-tanger-768x717.jpg 768w,
                /images/societe-nettoyage-tanger-300x280.jpg 300w"
          sizes="(max-width:1024px) 100vw, 50vw"
        />
      </div>
    </div>
  </section>

  <section class="dom-services-section" id="intro">
    <div class="dom-services-inner">
      <!-- Top Row: text column + video column -->
      <div class="dom-services-top">
        <!-- Left: heading, logo, description -->
        <div class="dom-services-text">
          <h2 class="dom-services-title">Société de nettoyage à domicile</h2>
          <div class="dom-services-logo">
            <img
              decoding="async"
              width="1024"
              height="292"
              src="/images/ominta-domestic-e1755508725634-1024x292.webp"
              alt="logo ominta domestic"
              srcset="/images/ominta-domestic-e1755508725634-1024x292.webp 1024w,
                    /images/ominta-domestic-e1755508725634-768x219.webp 768w,
                    /images/ominta-domestic-e1755508725634-300x85.webp 300w"
              sizes="(max-width:1024px) 100vw, 1024px"
            />
          </div>
          <p class="dom-services-desc">
            Ominta Domestic, spécialisée dans le nettoyage à domicile,
            transforme vos intérieurs en espaces sains, agréables et
            accueillants pour vous et vos proches. Que vous viviez en <strong
              >appartement, en villa ou en maison</strong
            >, nos services s'adaptent à votre mode de vie, à votre <strong
              >emploi du temps</strong
            > et à vos besoins uniques.
          </p>
        </div>

        <!-- Right: YouTube embed -->
        <div class="dom-services-video">
          <div class="dom-video-wrapper">
            <iframe
              src="https://www.youtube.com/embed/zGwQyOl51QA?controls=1&rel=0&playsinline=0&autoplay=0"
              title="Move-Out Cleaning Service – See the Ominta Difference!"
              frameborder="0"
              allowfullscreen
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              loading="lazy"></iframe>
          </div>
        </div>
      </div>

      <!-- Bottom Row: 2 service cards -->
      <div class="dom-services-cards">
        <!-- Card 1: Femme de ménage -->
        <div class="dom-service-card">
          <div class="dom-card-image">
            <img
              loading="lazy"
              decoding="async"
              width="1050"
              height="608"
              src="/images/societe-femme-menage-tanger.jpg"
              alt="Femme de ménage à Tanger"
              srcset="/images/societe-femme-menage-tanger.jpg 1050w,
                    /images/societe-femme-menage-tanger-1024x593.jpg 1024w,
                    /images/societe-femme-menage-tanger-768x445.jpg 768w,
                    /images/societe-femme-menage-tanger-300x174.jpg 300w"
              sizes="(max-width:1050px) 100vw, 1050px"
            />
          </div>
          <div class="dom-card-body">
            <h3 class="dom-card-title">Femme de menage</h3>
            <p>
              Ménage tout inclus avec produits et matériel · Femmes de ménage
              formées et qualifiées · Disponibles partout à Tanger (Gzenaya,
              Mesnana, Jbel Kebir, Rmilet, California, Malabata, Nejma) pour
              villas, appartements et maisons.
            </p>
          </div>
        </div>

        <!-- Card 2: Nettoyage canapé -->
        <div class="dom-service-card">
          <div class="dom-card-image">
            <img
              loading="lazy"
              decoding="async"
              width="1050"
              height="608"
              src="/images/nettoyage-canape-tanger.jpg"
              alt="Nettoyage Canapé à Tanger"
              srcset="/images/nettoyage-canape-tanger.jpg 1050w,
                    /images/nettoyage-canape-tanger-1024x593.jpg 1024w,
                    /images/nettoyage-canape-tanger-768x445.jpg 768w,
                    /images/nettoyage-canape-tanger-300x174.jpg 300w"
              sizes="(max-width:1050px) 100vw, 1050px"
            />
          </div>
          <div class="dom-card-body">
            <h3 class="dom-card-title">Nettoyage canapé</h3>
            <p>
              Intervention à domicile à Tanger pour le nettoyage à la vapeur de
              votre canapé en tissu · Canapés, tapis, chaises… disponibles à
              proximité de chez vous, dans tous les quartiers de Tanger, en
              urgence ou sur rendez-vous.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <WhyChooseSection />

  <AboutSection
    title="Nos services de nettoyage à domicile"
    paragraphs={[
      {
        html: `Chez Ominta Domestic, nous proposons une large gamme de solutions de nettoyage à domicile adaptées à tous les types de résidences — qu'il s'agisse d'appartements en centre-ville, de maisons familiales ou encore de villas haut de gamme.`,
      },
      {
        html: `Notre mission est de créer des espaces propres, agréables et sains, pour que vous puissiez profiter pleinement de votre quotidien, en toute sérénité.`,
      },
      {
        html: `Nos services couvrent toutes les prestations essentielles : le nettoyage régulier (quotidien, hebdomadaire ou mensuel), le grand ménage en profondeur pour cuisines, salles de bain et surfaces, ainsi que le nettoyage des tissus et moquettes pour redonner vie à vos canapés, tapis et fauteuils.`,
      },
      {
        html: `Nous assurons également le nettoyage lors d'un déménagement pour laisser vos anciens lieux impeccables et vos nouveaux espaces prêts à accueillir votre famille. Après des travaux, notre service de nettoyage post-rénovation prend en charge la poussière et les débris pour un intérieur parfaitement propre.`,
      },
      {
        html: `Nous proposons aussi le lavage de vitres et surfaces vitrées pour une transparence éclatante, le nettoyage d'événements avant et après vos réceptions, ainsi que des prestations de nettoyage écologique avec des <a href="https://www.onssa.gov.ma/reglementation/reglementation-sectorielle/produits-alimentaires/produits-dorigine-vegetale/" target="_blank" rel="noopener">produits certifiés ONSSA</a>, respectueux de votre santé et de l'environnement.`,
      },
      {
        html: `Chaque formule est entièrement personnalisée selon la configuration de votre habitation, vos priorités de nettoyage, vos besoins familiaux et votre disponibilité.`,
      },
      {
        html: `Avec Ominta Domestic, vous bénéficiez de services professionnels sur mesure, pensés pour simplifier votre quotidien et améliorer votre qualité de vie.`,
      },
    ]}
    mapSrc="https://maps.google.com/maps?width=100%25&height=100%25&hl=en&q=35.77067665248922,%20-5.810104635580955&t=&z=14&ie=UTF8&iwloc=B&output=embed"
  />
  <TestimonialsSection />

  <FAQSection />
</Layout>

<style>
  .dom-hero {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    margin: 0;
    padding: 0;
    overflow: hidden;
    position: relative;
  }

  /* Full-bleed background image on the right half */
  .dom-hero::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background-image: url("/images/societe-de-nettoyage-tanger.jpg");
    background-position: center left;
    background-size: cover;
    z-index: 0;
  }

  .dom-hero-inner {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── LEFT: text column ────────────────────────────── */
  .dom-hero-left {
    flex: 0 0 50%;
    width: 50%;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .dom-hero-content {
    max-width: 610px;
    padding: 100px 50px 100px 10px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Logo */
  .dom-logo {
    margin-bottom: 24px;
  }

  .dom-logo img {
    width: 45%;
    height: auto;
    display: block;
  }

  .dom-hero-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-size: 65px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 20px 0;
    letter-spacing: -0.025em;
  }

  .dom-hero-desc {
    color: #4b4848;
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 24px 0;
  }

  .dom-hero-reviews {
    text-align: left;
    margin-bottom: 30px;
  }

  .dom-hero-reviews img {
    width: 48%;
    height: auto;
    filter: brightness(96%) contrast(112%) saturate(100%);
    pointer-events: none;
  }

  /* CTA */
  .dom-hero-cta {
    display: flex;
    gap: 42px;
    margin-top: 30px;
  }

  .dom-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-image: linear-gradient(85deg, #d44091 35%, #a60e61 100%);
    color: #ffffff;
    padding: 17px 50px;
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .dom-hero-btn:hover {
    opacity: 0.88;
    color: #ffffff;
  }

  /* ── RIGHT: form column ───────────────────────────── */
  .dom-hero-right {
    flex: 0 0 43%;
    width: 43%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 80px 0;
  }

  .dom-hero-form-wrapper {
    max-width: 540px;
    width: 100%;
  }

  .dom-hero-form-card {
    background-image: linear-gradient(109deg, #d44091 32%, #5e1c40 98%);
    border-radius: 4px;
    padding: 50px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dom-form-label-top {
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 -15px 0;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .dom-form-sublabel {
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-size: 17px;
    margin: 0 0 8px 0;
  }

  .dom-callback-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dom-callback-form input {
    background-color: #ffffff;
    border: none;
    outline: none;
    padding: 12px 14px;
    font-family: "Poppins", sans-serif;
    font-size: 0.9rem;
    color: #333;
    width: 100%;
    box-sizing: border-box;
  }

  .dom-callback-form input::placeholder {
    color: #888;
  }

  .dom-form-submit {
    background-color: #e4f1ed;
    border: none;
    color: #333;
    font-family: "Poppins", sans-serif;
    font-size: 1rem;
    padding: 18px 0;
    width: 100%;
    cursor: pointer;
    margin-top: 4px;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .dom-form-submit:hover {
    background-color: #1f880f;
    color: #ffffff;
  }

  /* ═══════════════════════════════════════════════════
     RESPONSIVE – tablet ≤ 1024px
  ═══════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .dom-hero-inner {
      flex-direction: column;
    }

    .dom-hero-left,
    .dom-hero-right {
      flex: none;
      width: 100%;
    }

    .dom-hero::after {
      display: none;
    }

    .dom-hero-left {
      justify-content: flex-start;
      align-items: flex-start;
    }

    .dom-hero-content {
      max-width: 100%;
      padding: 90px 10px;
    }

 
    .dom-hero-cta {
      justify-content: center;
      align-items: center;
    }

    .dom-hero-right {
      padding: 10px;
      position: relative;
    }

    .dom-hero-right::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image: url("/images/societe-de-nettoyage-tanger.jpg");
      background-position: center;
      background-size: cover;
      z-index: -1;
    }

    .dom-hero-form-wrapper {
      max-width: 540px;
      margin: 0 auto;
      padding: 0 10px;
    }

    .dom-hero-form-card {
      padding: 50px 20px;
      gap: 5px;
    }

    .dom-form-label-top {
      font-size: 28px;
    }

    .dom-form-sublabel {
      font-size: 15px;
    }
  }

  /* ═══════════════════════════════════════════════════
     RESPONSIVE – mobile ≤ 767px
  ═══════════════════════════════════════════════════ */
  @media (max-width: 767px) {
    .dom-hero-content {
      padding: 40px 25px;
    }

    .dom-hero-title {
      font-size: 40px;
      line-height: 1.1;
    }

    .dom-logo img {
      width: 59%;
    }

    .dom-hero-reviews img {
      width: 77%;
    }

    .dom-hero-cta {
      display: none;
    }

    .dom-hero-right {
      min-height: 350px;
      padding: 0;
    }

    .dom-hero-form-wrapper {
      width: 93%;
      margin: 0 auto;
    }

    .dom-hero-form-card {
      padding: 50px 20px;
      gap: 5px;
      margin: 20px 0;
    }

    .dom-form-label-top {
      font-size: 20px;
      line-height: 1.5;
    }
  }

  @media (min-width: 768px) {
    .dom-hero-reviews img {
      width: 48%;
    }
  }

  /* ═══════════════════════════════════════════════════
     DOM-INTRO SECTION — element-2c64171
     Source: post-28177.css — 56ba25f, 930abeb, d9b35e1
  ═══════════════════════════════════════════════════ */
  .dom-intro-section {
    padding-top: 120px;
    padding-bottom: 0;
    background-color: #ffffff;
    overflow: hidden;
  }

  .dom-intro-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 0;
  }

  /* Left column: text + CTA */
  .dom-intro-text-col {
    flex: 0 0 50%;
    width: 50%;
    padding-right: 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
  }

  .dom-intro-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-size: 50px;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 20px 0;
  }

  .dom-intro-desc p {
    color: #4b4848;
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    line-height: 1.7;
    margin: 0 0 14px 0;
  }

  .dom-intro-desc p:last-child {
    margin-bottom: 0;
  }

  .dom-intro-desc a {
    color: #d44091;
  }

  .dom-intro-desc a:hover {
    color: #a60e61;
  }

  .dom-intro-cta {
    margin-top: 30px;
  }

  .dom-intro-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-image: linear-gradient(85deg, #d44091 35%, #a60e61 100%);
    color: #ffffff;
    padding: 17px 50px;
