---
import Layout from "../layouts/Layout.astro";
import WhyChooseSection from "../components/WhyChooseSection.astro";
import AboutSection from "../components/AboutSection.astro";
import FAQSection from "../components/FAQSection.astro";
import TestimonialsSection from "../components/TestimonialsSection.astro";
---

<Layout title="Ominta Domestic | Service de nettoyage à domicile à Tanger">
    <section class="dom-hero">
        <div class="dom-hero-inner">
            <!-- Left column: logo + text + reviews + CTA -->
            <div class="dom-hero-left">
                <div class="dom-hero-content">
                    <h1 class="dom-hero-title">Femme de ménage Tanger</h1>

                    <p class="dom-hero-desc">
                        ominta est une société spécialisée dans le ménage à
                        domicile, mettant à votre disposition une Femme de
                        ménage Tanger, des baby-sitters sérieuses et des
                        cuisinières qualifiées.
                    </p>

                    <div class="dom-hero-reviews">
                        <img
                            decoding="async"
                            width="1024"
                            height="229"
                            src="/images/avis-nettoyage-tanger-e1755459834916-1024x229.png"
                            alt="Avis Ominta Société de nettoyage à Tanger"
                            srcset="/images/avis-nettoyage-tanger-e1755459834916-1024x229.png 1024w,
                    /images/avis-nettoyage-tanger-e1755459834916-768x171.png 768w,
                    /images/avis-nettoyage-tanger-e1755459834916-300x67.png 300w"
                            sizes="(max-width:1024px) 100vw, 1024px"
                        />
                    </div>

                    <div class="dom-hero-cta">
                        <a href="/contact" class="dom-hero-btn">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="13"
                                height="13"
                                viewBox="0 0 512 512"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    d="M502.3 190.8c3.9-3.1 9.7-.2 9.7 4.7V400c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V195.6c0-5 5.7-7.8 9.7-4.7 22.4 17.4 52.1 39.5 154.1 113.6 21.1 15.4 56.7 47.8 92.2 47.6 35.7.3 72-32.8 92.3-47.6 102-74.1 131.6-96.3 154-113.7zM256 320c23.2.4 56.6-29.2 73.4-41.4 132.7-96.3 142.8-104.7 173.4-128.7 5.8-4.5 9.2-11.5 9.2-18.9v-19c0-26.5-21.5-48-48-48H48C21.5 64 0 85.5 0 112v19c0 7.4 3.4 14.3 9.2 18.9 30.6 23.9 40.7 32.4 173.4 128.7 16.8 12.2 50.2 41.8 73.4 41.4z"
                                ></path>
                            </svg>
                            <span>Réserver maintenant</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Right column: background image + callback form -->
            <div class="dom-hero-right">
                <div class="dom-hero-form-wrapper">
                    <div class="dom-hero-form-card">
                        <p class="dom-form-label-top">
                            RAPPEL GRATUIT ET IMMÉDIAT
                        </p>
                        <p class="dom-form-sublabel">
                            Un conseiller vous appellera dans quelques instants.
                        </p>

                        <form
                            class="dom-callback-form"
                            action="#"
                            method="post"
                            novalidate
                        >
                            <input
                                id="dom-hero-name"
                                type="text"
                                name="your-name"
                                placeholder="Nom complet *"
                                autocomplete="name"
                                required
                                maxlength="400"
                            />
                            <input
                                id="dom-hero-phone"
                                type="tel"
                                name="phone-number"
                                placeholder="Téléphone *"
                                autocomplete="tel"
                                required
                                maxlength="400"
                            />
                            <button type="submit" class="dom-form-submit"
                                >Envoyer</button
                            >
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="dom-intro-section">
        <div class="dom-intro-inner">
            <!-- Left: Text + CTA -->
            <div class="dom-intro-text-col">
                <h2 class="dom-intro-title">Femme de ménage à Tanger</h2>
                <div class="dom-intro-desc">
                    <p>
                        À Tanger, réservez facilement une femme de ménage pour
                        un grand ménage, des passages réguliers ou l’entretien
                        de votre cuisine. Nos intervenantes assurent un service
                        soigné pour un espace propre et agréable. Nos femmes de
                        ménage Tanger sont qualifiées, sélectionnées avec
                        rigueur et offrent une prestation sécurisée et de
                        confiance. Vous pouvez compter sur leur sérieux et leur
                        professionnalisme au quotidien.
                    </p>
                    <p>
                        En plus du ménage, nous proposons aussi des services de
                        baby-sitter et d’assistance aux personnes âgées, afin de
                        vous garantir confort et tranquillité à domicile.
                    </p>
                    <p>
                        Appelez dès maintenant le <a href="tel:+212670077979"
                            >(+212) 670-077-979</a
                        > et réservez une femme de ménage qualifiée, disponible et
                        à l’écoute de vos besoins.
                    </p>
                </div>
                <div class="dom-intro-cta">
                    <a href="/contact" class="dom-intro-btn">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="13"
                            height="13"
                            viewBox="0 0 512 512"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M502.3 190.8c3.9-3.1 9.7-.2 9.7 4.7V400c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V195.6c0-5 5.7-7.8 9.7-4.7 22.4 17.4 52.1 39.5 154.1 113.6 21.1 15.4 56.7 47.8 92.2 47.6 35.7.3 72-32.8 92.3-47.6 102-74.1 131.6-96.3 154-113.7zM256 320c23.2.4 56.6-29.2 73.4-41.4 132.7-96.3 142.8-104.7 173.4-128.7 5.8-4.5 9.2-11.5 9.2-18.9v-19c0-26.5-21.5-48-48-48H48C21.5 64 0 85.5 0 112v19c0 7.4 3.4 14.3 9.2 18.9 30.6 23.9 40.7 32.4 173.4 128.7 16.8 12.2 50.2 41.8 73.4 41.4z"
                            ></path>
                        </svg>
                        <span>Réserver maintenant</span>
                    </a>
                </div>
            </div>
            <div class="dom-intro-image-col">
                <img
                    loading="lazy"
                    decoding="async"
                    width="1024"
                    height="957"
                    src="/images/societe-nettoyage-tanger-1024x957.jpg"
                    alt="Femme de ménage à Tanger"
                    srcset="/images/societe-nettoyage-tanger-1024x957.jpg 1024w,
                /images/societe-nettoyage-tanger-768x717.jpg 768w,
                /images/societe-nettoyage-tanger-300x280.jpg 300w"
                    sizes="(max-width:1024px) 100vw, 50vw"
                />
            </div>
        </div>
    </section>

    <section class="dom-intro-section reversed">
        <div class="dom-intro-inner">
            <!-- Left: Text -->
            <div class="dom-intro-text-col">
                <h2 class="dom-intro-title">Service femme de ménage Tanger</h2>
                <div class="dom-intro-desc">
                    <p>
                        Nos services de femme de ménage à Tanger reposent sur
                        des profils soigneusement sélectionnés, déclarés et
                        assurés pour garantir un travail professionnel et de
                        confiance.
                    </p>
                    <p>
                        Disponibles dans tous les quartiers de Tanger, nos
                        équipes interviennent aussi bien à Malabata, Jbel Kbir,
                        Branes, Nejma, Centre-ville, Marshan ou encore Gzenaya.
                        Où que vous soyez, vous bénéficiez d’une femme de ménage
                        qualifiée, fiable et proche de vous pour répondre à vos
                        besoins quotidiens ou ponctuels. Déjà, nous gérons le
                        ménage de plusieurs appartements, villas et résidences,
                        ainsi que de nombreux logements Airbnb et <a
                            href="https://www.booking.com/city/ma/tangier.fr.html"
                            target="_blank"
                            style="text-decoration: underline;">Booking</a
                        > à Nejma et dans d’autres quartiers de Tanger.
                    </p>
                    <p>
                        Notre expérience sur le terrain nous permet d’offrir un
                        service organisé, sécurisé et parfaitement adapté aux
                        exigences de chaque client.
                    </p>
                </div>

                <div class="dom-intro-cta">
                    <a href="/contact" class="dom-intro-btn">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="13"
                            height="13"
                            viewBox="0 0 512 512"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M502.3 190.8c3.9-3.1 9.7-.2 9.7 4.7V400c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V195.6c0-5 5.7-7.8 9.7-4.7 22.4 17.4 52.1 39.5 154.1 113.6 21.1 15.4 56.7 47.8 92.2 47.6 35.7.3 72-32.8 92.3-47.6 102-74.1 131.6-96.3 154-113.7zM256 320c23.2.4 56.6-29.2 73.4-41.4 132.7-96.3 142.8-104.7 173.4-128.7 5.8-4.5 9.2-11.5 9.2-18.9v-19c0-26.5-21.5-48-48-48H48C21.5 64 0 85.5 0 112v19c0 7.4 3.4 14.3 9.2 18.9 30.6 23.9 40.7 32.4 173.4 128.7 16.8 12.2 50.2 41.8 73.4 41.4z"
                            ></path>
                        </svg>
                        <span>Réserver maintenant</span>
                    </a>
                </div>
            </div>
            <!-- Right: Second Image -->
            <div class="dom-intro-image-col">
                <img
                    loading="lazy"
                    decoding="async"
                    width="1024"
                    height="957"
                    src="/images/femme-menage-tanger-1024x957.jpg"
                    alt="Service femme de ménage Tanger"
                    style="object-fit: cover;"
                />
            </div>
        </div>
    </section>

    <section class="dom-services-section" id="intro">
        <div class="dom-services-inner">
            <!-- Top Row: text column + video column -->
            <div class="dom-services-top">
                <!-- Left: heading, logo, description -->
                <div class="dom-services-text">
                    <h2 class="dom-services-title">
                        Société de nettoyage à domicile
                    </h2>
                    <div class="dom-services-logo">
                        <img
                            decoding="async"
                            width="1024"
                            height="292"
                            src="/images/ominta-domestic-e1755508725634-1024x292.webp"
                            alt="logo ominta domestic"
                            srcset="/images/ominta-domestic-e1755508725634-1024x292.webp 1024w,
                    /images/ominta-domestic-e1755508725634-768x219.webp 768w,
                    /images/ominta-domestic-e1755508725634-300x85.webp 300w"
                            sizes="(max-width:1024px) 100vw, 1024px"
                        />
                    </div>
                    <p class="dom-services-desc">
                        Ominta Domestic, spécialisée dans le nettoyage à
                        domicile, transforme vos intérieurs en espaces sains,
                        agréables et accueillants pour vous et vos proches. Que
                        vous viviez en <strong
                            >appartement, en villa ou en maison</strong
                        >, nos services s'adaptent à votre mode de vie, à votre <strong
                            >emploi du temps</strong
                        > et à vos besoins uniques.
                    </p>
                </div>

                <!-- Right: YouTube embed -->
                <div class="dom-services-video">
                    <div class="dom-video-wrapper">
                        <iframe
                            src="https://www.youtube.com/embed/zGwQyOl51QA?controls=1&rel=0&playsinline=0&autoplay=0"
                            title="Move-Out Cleaning Service – See the Ominta Difference!"
                            frameborder="0"
                            allowfullscreen
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            referrerpolicy="strict-origin-when-cross-origin"
                            loading="lazy"></iframe>
                    </div>
                </div>
            </div>

            <!-- Bottom Row: 2 service cards -->
            <div class="dom-services-cards">
                <!-- Card 1: Femme de ménage -->
                <div class="dom-service-card">
                    <div class="dom-card-image">
                        <img
                            loading="lazy"
                            decoding="async"
                            width="1050"
                            height="608"
                            src="/images/societe-femme-menage-tanger.jpg"
                            alt="Femme de ménage à Tanger"
                            srcset="/images/societe-femme-menage-tanger.jpg 1050w,
                    /images/societe-femme-menage-tanger-1024x593.jpg 1024w,
                    /images/societe-femme-menage-tanger-768x445.jpg 768w,
                    /images/societe-femme-menage-tanger-300x174.jpg 300w"
                            sizes="(max-width:1050px) 100vw, 1050px"
                        />
                    </div>
                    <div class="dom-card-body">
                        <h3 class="dom-card-title">Femme de menage</h3>
                        <p>
                            Ménage tout inclus avec produits et matériel ·
                            Femmes de ménage formées et qualifiées · Disponibles
                            partout à Tanger (Gzenaya, Mesnana, Jbel Kebir,
                            Rmilet, California, Malabata, Nejma) pour villas,
                            appartements et maisons.
                        </p>
                    </div>
                </div>

                <!-- Card 2: Nettoyage canapé -->
                <div class="dom-service-card">
                    <div class="dom-card-image">
                        <img
                            loading="lazy"
                            decoding="async"
                            width="1050"
                            height="608"
                            src="/images/nettoyage-canape-tanger.jpg"
                            alt="Nettoyage Canapé à Tanger"
                            srcset="/images/nettoyage-canape-tanger.jpg 1050w,
                    /images/nettoyage-canape-tanger-1024x593.jpg 1024w,
                    /images/nettoyage-canape-tanger-768x445.jpg 768w,
                    /images/nettoyage-canape-tanger-300x174.jpg 300w"
                            sizes="(max-width:1050px) 100vw, 1050px"
                        />
                    </div>
                    <div class="dom-card-body">
                        <h3 class="dom-card-title">Nettoyage canapé</h3>
                        <p>
                            Intervention à domicile à Tanger pour le nettoyage à
                            la vapeur de votre canapé en tissu · Canapés, tapis,
                            chaises… disponibles à proximité de chez vous, dans
                            tous les quartiers de Tanger, en urgence ou sur
                            rendez-vous.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <WhyChooseSection 
        title="Pourquoi choisir nos femmes de ménage à Tanger"
        items={[
            {
                title: "Intervenants experts et sélectionnés",
                desc: "Tous nos femmes de ménage disposent d’une solide expérience en nettoyage à domicile et en bureaux, et suivent une formation spécialisée dispensée par notre société de nettoyage, garantissant des prestations de qualité."
            },
            {
                title: "Intervenants déclarés et assurés",
                desc: "Avec nos femmes de ménage déclarés et assurés, vous bénéficiez d’une prestation fiable, conforme aux normes d’hygiène et de sécurité."
            }
        ]}
    />

    <AboutSection
        title="Pourquoi Ominta pour femme de ménage Tanger ?"
        paragraphs={[
            {
                html: `Chez Ominta, nous savons que le ménage ne se résume pas simplement à la propreté : il s’agit de confiance, de sécurité et de continuité. C’est pourquoi nous avons mis en place un processus rigoureux pour sélectionner et former nos femmes de ménage. Chaque profil est soigneusement recruté, déclaré et assuré afin de garantir une <a href="https://www.ominta.ma/ominta-commercial/">prestation professionnelle</a> et fiable. Nos équipes suivent des formations régulières, aussi bien sur les techniques de nettoyage que sur le respect des normes d’hygiène et de sécurité. Ainsi, vous bénéficiez de services conformes aux standards les plus élevés, que ce soit pour votre appartement, votre villa ou vos locaux professionnels.`,
            },
            {
                html: `L’un des atouts majeurs d’Ominta est son service d’assistance professionnelle. Même si vous n’êtes pas sur Tanger, notre équipe assure la gestion complète de votre ménage à distance. Par exemple, nous travaillons avec plusieurs clients résidant à l’étranger qui nous confient l’entretien de leurs biens, leurs résidences secondaires ou leurs appartements mis en location saisonnière. De plus, en cas de besoin ou d’absence de votre femme de ménage habituelle, nous assurons immédiatement un suivi et un remplacement rapide, afin de maintenir une continuité sans faille dans vos prestations.`,
            },
            {
                html: `Nous sommes également très attentifs à la relation de confiance qui s’installe avec nos clients. Prenons l’exemple de Mme Amira Benjelloun, qui nous a confié l’entretien complet de son appartement de luxe à Malabata Hills : elle bénéficie d’un suivi régulier et de femmes de ménage qualifiées qui respectent la confidentialité et l’organisation de son habitat. Autre illustration : Nabile, résident aux Pays-Bas, nous a confié la gestion de ses quatre appartements prestigieux AIRBNB à Tanger. Grâce à Ominta, il n’a plus à se soucier de la logistique : chaque logement est entretenu avec rigueur, préparé pour ses clients et conforme aux exigences d’hygiène des plateformes de location internationale.`,
            },
            {
                html: `Au-delà des prestations ponctuelles, Ominta propose également des contrats de ménage personnalisés. Cela permet aux particuliers comme aux entreprises de bénéficier d’une organisation claire, d’une régularité dans les interventions et d’une équipe toujours disponible. Aujourd’hui, nous avons la confiance de plus de 500 clients à Tanger et dans ses quartiers les plus prestigieux (Malabata, <a href="https://www.avito.ma/sp/immobilier/villa-a-jbel-kbir-tanger">Jbel Kbir</a>, Branes, Nejma, Gzenaya, etc.), qu’il s’agisse de familles, de professionnels ou de propriétaires immobiliers.`,
            },
            {
                html: `En choisissant Ominta, vous choisissez plus qu’un simple service de ménage : vous optez pour une solution complète, sécurisée et adaptée à vos besoins. Notre objectif est simple : vous offrir la tranquillité d’esprit et un environnement impeccable, que vous soyez sur place ou à des milliers de kilomètres.`,
            },
        ]}
        mapSrc=""
    />
    <TestimonialsSection />

    <FAQSection
        items={[
            {
                question:
                    "Quel est l’intérêt de faire appel à Ominta plutôt qu’embaucher directement une femme de ménage Tanger ?",
                answerHtml:
                    "<p>Lorsque vous embauchez directement une femme de ménage, vous devez gérer vous-même de nombreux aspects administratifs et organisationnels : contrat, assurance, remplacement en cas d’absence, formation, fiabilité… Avec Ominta, tout cela est simplifié. Nous sélectionnons nos profils de manière rigoureuse, nous les déclarons et les assurons, et nous vous garantissons une continuité de service. Vous n’avez pas à vous soucier des imprévus, ni des démarches compliquées : nous nous occupons de tout.</p><p>De plus, faire appel à Ominta vous permet de bénéficier d’un suivi professionnel et d’un encadrement sérieux. Nous mettons à votre disposition une assistance réactive, un contrôle de qualité et un système de remplacement immédiat en cas d’absence de votre femme de ménage habituelle. En d’autres termes, vous avez la tranquillité d’esprit d’un service structuré, fiable et encadré, ce qu’un recrutement direct ne peut garantir.</p>",
            },
            {
                question: "Pourquoi choisir nos femmes de ménage à Tanger ?",
                answerHtml:
                    "<p>La différence d’Ominta réside dans notre engagement sur la qualité et la sécurité.</p><p>Contrairement à certaines agences qui se contentent de placer du personnel, nous assurons un suivi réel de chaque intervention. Nous formons nos femmes de ménage aux normes d’hygiène et de sécurité, et nous veillons à ce que chaque client soit satisfait sur le long terme.</p><p>Nos prestations ne sont pas standardisées : elles sont adaptées à chaque logement et à chaque besoin spécifique. Nous avons également bâti une solide réputation à Tanger grâce à la confiance de centaines de clients. Plus de 500 particuliers et professionnels nous ont choisis pour la fiabilité de nos services et notre réactivité.</p><p>Cette expérience et cette satisfaction client font d’Ominta une société de référence, ce qui nous distingue largement des agences classiques qui privilégient souvent le volume au détriment de la qualité.</p>",
            },
            {
                question:
                    "Quel est le tarif d’une prestation de ménage à domicile à Tanger ?",
                answerHtml:
                    "<p>Nos tarifs sont étudiés pour rester accessibles tout en garantissant un service professionnel. Le coût dépend de plusieurs facteurs : la fréquence des interventions (quotidienne, hebdomadaire ou ponctuelle), la taille de l’habitation, et les services complémentaires souhaités (repassage, assistance Airbnb, nettoyage en profondeur, etc.).</p><p>Nous proposons à la fois des prestations à l’heure et des contrats personnalisés pour les clients qui recherchent une solution stable et régulière. Chaque devis est transparent et détaillé, sans frais cachés.</p><p>Nous croyons en une relation de confiance claire avec nos clients : vous savez exactement ce que vous payez et pour quel service. Cette transparence, combinée à notre flexibilité, vous permet de choisir la formule la plus adaptée à votre budget et à vos attentes.</p>",
            },
            {
                question:
                    "Est-ce que je peux laisser mes clés à votre agence de ménage à domicile ?",
                answerHtml:
                    "<p>Oui, plusieurs de nos clients nous confient les clés de leur logement pour plus de praticité. Cela leur permet de profiter du service même en leur absence, sans avoir à s’organiser pour chaque intervention.</p><p>Nous disposons de procédures strictes pour assurer la sécurité et la confidentialité : chaque clé est étiquetée de manière anonyme et conservée avec soin dans un système sécurisé.</p><p>Cette solution est particulièrement appréciée des clients qui voyagent fréquemment, ou qui possèdent des appartements secondaires à Tanger. Ainsi, ils retrouvent leur logement toujours propre et prêt à l’usage, qu’il s’agisse d’une résidence personnelle ou d’un bien en location.</p>",
            },
            {
                question: "Ma femme de ménage est malade. Comment procéder ?",
                answerHtml:
                    "<p>Si votre femme de ménage habituelle est absente pour cause de maladie, vous n’avez aucune inquiétude à avoir.</p><p>Contrairement à l’embauche directe, où l’absence bloque totalement le service, Ominta prévoit un système de remplacement immédiat.</p>",
            },
        ]}
    />
</Layout>

<style>
    .dom-hero {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        margin: 0;
        padding: 0;
        overflow: hidden;
        position: relative;
    }

    /* Full-bleed background image on the right half */
    .dom-hero::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 50%;
        height: 100%;
        background-image: url("/images/societe-de-nettoyage-tanger.jpg");
        background-position: center left;
        background-size: cover;
        z-index: 0;
    }

    .dom-hero-inner {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    /* ── LEFT: text column ────────────────────────────── */
    .dom-hero-left {
        flex: 0 0 50%;
        width: 50%;
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }

    .dom-hero-content {
        max-width: 610px;
        padding: 100px 50px 100px 10px;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    /* Logo */
    .dom-logo {
        margin-bottom: 24px;
    }

    .dom-logo img {
        width: 45%;
        height: auto;
        display: block;
    }

    .dom-hero-title {
        color: #000000;
        font-family: "Poppins", sans-serif;
