---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contactez-nous | Société de nettoyage Tanger - Ominta">
  <section class="hero">
    <div class="hero-inner">
      <!-- Left column: text + buttons -->
      <div class="hero-left">
        <div class="hero-content">
          <h1 class="hero-title">Contactez Ominta pour réserver votre service !</h1>
 
          <div class="hero-image">
            <img
              decoding="async"
              width="1024"
              height="250"
              src="/images/ominta-contact-e1755529103342-1024x250.jpg"
              alt="Contact Ominta Tanger"
            />
          </div>

          <div class="hero-address">
            <p>
              N17, Etage 05, IMM AL Fath Bloc A, Avenue Moulay Youssef, Tanger – Maroc.
            </p>
          </div>

          <div class="hero-contact-buttons">
            <a href="tel:+212670077979" class="contact-btn">
              +212 670 077 979
            </a>
            <a href="mailto:info@ominta-ausmaroc.com" class="contact-btn outline">
              info@ominta-ausmaroc.com
            </a>
          </div>
        </div>
      </div> 

      <!-- Right column: background image + callback form -->
      <div class="hero-right">
        <div class="hero-form-wrapper">
          <div class="hero-form-card">
            <p class="form-label-top">RAPPEL GRATUIT ET IMMÉDIAT</p>
            <p class="form-sublabel">
              Un conseiller vous appellera dans quelques instants.
            </p>

            <form class="callback-form" action="#" method="post" novalidate>
              <input
                id="hero-name"
                type="text"
                name="your-name"
                placeholder="Nom complet *"
                autocomplete="name"
                required
                maxlength="400"
              />
              <input
                id="hero-phone"
                type="tel"
                name="phone-number"
                placeholder="Téléphone *"
                autocomplete="tel"
                required
                maxlength="400"
              />
              <button type="submit" class="form-submit">Envoyer</button>
            </form>
          </div>
        </div>
      </div>
    </div><!-- /.hero-inner -->
  </section>
</Layout>

<style>
    
   /* Full-width outer shell — columns stretch edge-to-edge */
  .hero {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    margin: 0;
    padding: 0;
    overflow: hidden;
    position: relative;
    background-color: #ffffff;
  }

  /* Full-bleed background image on the right half */
  .hero::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background-image: url("/images/societe-de-nettoyage-tanger.jpg");
    background-position: center left;
    background-size: cover;
    z-index: 0;
  }

  .hero-inner {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── LEFT: text column ───────────────────────────── */
  .hero-left {
    flex: 0 0 50%;
    width: 50%;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .hero-content {
    max-width: 610px;
    padding: 140px 50px 130px 10px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-size: 50px;
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 20px 0;
    letter-spacing: -0.027em;
  }

  .hero-desc {
    color: #4b4848;
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 24px 0;
  }

  .hero-image {
    margin-bottom: 20px;
  }

  .hero-image img {
    width: 100%;
    max-width: 350px;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  .hero-address {
    margin-bottom: 30px;
  }

  .hero-address p {
    color: #4b4848;
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }

  .hero-contact-buttons {
    display: flex;
    flex-direction: column;
    gap: 15px;
    max-width: 100%;
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    background-color: #D4409100;
    padding: 10px 20px 10px 20px;
    font-family: "Poppins", Sans-serif;
    font-size: 30px;
    font-weight: 600;
    color: #000000;
    fill: #000000;
    border-style: dotted;
    border-width: 2px 2px 2px 2px;
    border-color: #000000;
    border-radius: 0px;
    width: fit-content;
  }

  .contact-btn:hover {
    color: #000000;
  }

  .contact-btn.outline {
    background-color: #D4409100;
    padding: 10px 20px 10px 20px;
    font-family: "Poppins", Sans-serif;
    font-size: 30px;
    font-weight: 600;
    color: #50A144;
    fill: #50A144;
    border-style: dotted;
    border-width: 2px 2px 2px 2px;
    border-color: #50A144;
    border-radius: 0px 0px 0px 0px;
  }

  .contact-btn.outline:hover {
    background-color: #50a144;
    color: #ffffff;
  }

  /* ── RIGHT: form column ───────────────────────────── */
  .hero-right {
    flex: 0 0 43%;
    width: 43%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 80px 0 80px 80px;
  }

  .hero-form-wrapper {
    max-width: 540px;
    width: 100%;
  }

  .hero-form-card {
    background-image: linear-gradient(109deg, #50a144 41%, #23511d 98%);
    border-radius: 4px;
    padding: 50px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-label-top {
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 -15px 0;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .form-sublabel {
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-size: 17px;
    margin: 0 0 8px 0;
  }

  /* Form fields */
  .callback-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .callback-form input {
    background-color: #ffffff;
    border: none;
    outline: none;
    padding: 12px 14px;
    font-family: "Poppins", sans-serif;
    font-size: 0.9rem;
    color: #333;
    width: 100%;
    box-sizing: border-box;
   }

  .callback-form input::placeholder {
    color: #888;
  }

  .form-submit {
    background-color: #e4f1ed;
    border: none;
    color: #333;
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 1rem;
    padding: 16px 0;
    width: 100%;
    cursor: pointer;
    margin-top: 4px;
     transition: background-color 0.2s ease, color 0.2s ease;
  }

  .form-submit:hover {
    background-color: #1f880f;
    color: #ffffff;
  }

  /* ═══════════════════════════════════════════════════
     RESPONSIVE – tablet ≤ 1024px
  ═══════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .hero-inner {
      flex-direction: column;
    }

    .hero-left,
    .hero-right {
      flex: none;
      width: 100%;
    }

    .hero-left {
      justify-content: flex-start;
      align-items: flex-start;
    }

    .hero-content {
      max-width: 100%;
      padding: 90px 20px;
    }

    .hero-right {
      padding: 10px 20px;
    }

    .hero-form-wrapper {
      max-width: 100%;
    }

    .hero-form-card {
      padding: 50px 30px;
    }
  }

  /* ═══════════════════════════════════════════════════
     RESPONSIVE – mobile ≤ 767px
  ═══════════════════════════════════════════════════ */
  @media (max-width: 767px) {
    .hero-content {
      padding: 40px 20px;
    }

    .hero-title {
      font-size: 40px;
      line-height: 1.1;
    }

    .hero-image img {
      max-width: 100%;
    }

    .hero-contact-buttons {
      max-width: 100%;
    }

    .hero-right {
      min-height: 350px;
      padding: 20px;
    }

    .hero-form-card {
      padding: 40px 20px;
    }

    .form-label-top {
      font-size: 20px;
      line-height: 1.4;
    }
  }
</style>
