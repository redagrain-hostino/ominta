---
const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/ominta-domestic", label: "Ominta Domestic" },
  { href: "/ominta-commercial", label: "Ominta Commercial" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname; 
---

<header id="site-header" class="site-header">
  <div class="header-inner">
    <div class="header-row">

      <!-- Logo -->
      <div class="header-logo">
        <a href="/" class="logo-link">
          <img
            fetchpriority="high"
            width="648"
            height="182"
            src="/images/logo-ominta.png"
            alt="logo-ominta"
          />
        </a>
      </div>

      <!-- Navigation -->
      <nav class="header-nav" aria-label="Navigation principale">
        <ul class="nav-list" id="main-menu">
          {navLinks.map((link) => (
            <li class="nav-item">
              <a
                href={link.href}
                class={`nav-link${currentPath === link.href ? " active" : ""}`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- CTA Button -->
      <div class="header-cta">
        <a href="tel:+212670077979" class="cta-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
            <path d="M497.39 361.8l-112-48a24 24 0 0 0-28 6.9l-49.6 60.6A370.66 370.66 0 0 1 91.18 154.4l60.6-49.6a23.94 23.94 0 0 0 6.9-28l-48-112A24.16 24.16 0 0 0 83.18.16L24 8C10.72 9.44 0 20.88 0 34.32 0 261.68 250.32 512 477.68 512c13.44 0 24.88-10.72 26.32-24l7.84-59.2a24.2 24.2 0 0 0-14.45-26z"/>
          </svg>
          <span>+212 670 07 79 79</span>
        </a>
      </div>

      <!-- Hamburger (mobile) -->
      <button class="hamburger" id="hamburger-btn" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="main-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

    </div>
  </div>

  <!-- Mobile overlay -->
  <div class="nav-overlay" id="nav-overlay"></div>
</header>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('main-menu');
  const overlay = document.getElementById('nav-overlay');

  function toggleMenu(open: boolean) {
    btn?.setAttribute('aria-expanded', String(open));
    menu?.classList.toggle('is-open', open);
    overlay?.classList.toggle('is-visible', open);
    document.body.classList.toggle('menu-open', open);
  }

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    toggleMenu(!isOpen);
  });

  overlay?.addEventListener('click', () => toggleMenu(false));
</script>

<style>
  /* ── Header shell ───────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background-color: #ffffff;
    border-bottom: 1px solid #E3E6EE;
    overflow: visible;
  }

  /* ── Inner wrapper (max-width container) ───────────────── */
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
  }

  /* ── Row: logo | nav | cta | hamburger ─────────────────── */
  .header-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    min-height: 80px;
    flex-wrap: nowrap;
    gap: 0;
  }

  .header-logo {
    flex: 0 0 auto;
    order: -1;
  }

  .logo-link img {
    width: 159px;
    height: auto;
    display: block;
  }

   .header-nav {
    display: flex;
    align-items: flex-end;
    padding: 0 10px;
    height: 80px;
  }

  .nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 20px;
    height: 100%;
  }

  .nav-item {
    margin-left: 5px;
  }

  .nav-link {
    font-family: "Poppins", sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    color: #222626;
    text-decoration: none;
    padding: 0;
    border: none;
    display: block;
    transition: color 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #1B9A44;
  }

  /* ── CTA Button ─────────────────────────────────────────── */
  .header-cta {
     display: flex;
    justify-content: flex-end;
   }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: #50A144;
    color: #ffffff;
    padding: 17px 50px;
    text-decoration: none;
    font-family: "Poppins", sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s ease, opacity 0.2s ease;
  }

  .cta-btn:hover {
    opacity: 0.88;
    color: #ffffff;
  }

  .cta-btn svg {
    flex-shrink: 0;
  }

  /* ── Hamburger (hidden on desktop) ─────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: #222626;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* ── Mobile overlay ─────────────────────────────────────── */
  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 998;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .nav-overlay.is-visible {
    display: block;
    opacity: 1;
  }

  /* ── Responsive: tablet ≤ 1024px ─────────────────────────── */
  @media (max-width: 1024px) {
    .header-row {
      min-height: 70px;
      flex-wrap: wrap;
    }

    .header-cta {
      width: auto;
      margin-left: auto;
      order: 2;
    }

    /* Hide CTA on tablet/mobile */
    .cta-btn {
      display: none;
    }

    .hamburger {
      display: flex;
      order: 3;
    }

    /* Slide-in mobile nav */
    .header-nav {
      position: fixed;
      top: 0;
      right: 0;
      transform: translateX(100%);
      width: 280px;
      height: 100vh;
      background: #ffffff;
      box-shadow: -4px 0 20px rgba(0,0,0,0.12);
      flex-direction: column;
      align-items: flex-start;
      padding: 80px 24px 24px;
      z-index: 999;
      transition: transform 0.3s ease;
      overflow-y: auto;
    }

    .header-nav .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      height: auto;
      width: 100%;
    }

    .header-nav .nav-item {
      margin-left: 0;
      width: 100%;
      border-bottom: 1px solid #E3E6EE;
    }

    .header-nav .nav-link {
      padding: 12px 0;
      display: block;
    }

    .header-nav .nav-list.is-open {
      /* list itself doesn't animate; the nav panel does */
    }

    /* When menu is open, slide nav into view */
    :global(body.menu-open) .header-nav {
      transform: translateX(0);
    }
  }

  /* ── Responsive: mobile ≤ 767px ────────────────────────── */
  @media (max-width: 767px) {
    .header-logo {
      width: auto;
    }
  }
</style>