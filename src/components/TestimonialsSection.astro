<style>
  /* ── Outer section: 59a208a ─────────────────────────── */
  .testimonials-section {
    padding: 100px 0 140px 0;
    background-color: #ffffff;
    overflow: hidden;
  }

  /* Centered 1200px grid */
  .testimonials-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  /* ── Header ─────────────────────────────────────────── */
  .testimonials-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
  }

  /* Subtitle text (ekit-heading__subtitle) */
  .testimonials-subtitle {
    color: #ffa733;
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    letter-spacing: 1px;
    position: relative;
    display: inline-block;
  }

  .testimonials-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-size: 50px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    max-width: 800px;
  }

  /* ── CSS Snap Slider ─────────────────────────────────── */
  .testimonials-slider {
    display: flex;
    flex-direction: row;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 20px; /* Space for scrollbar */

    /* Hide scrollbar for a cleaner look while keeping functionality */
    scrollbar-width: thin;
    scrollbar-color: #50a144 #f1f1f1;
  }

  .testimonials-slider::-webkit-scrollbar {
    height: 6px;
  }

  .testimonials-slider::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 6px;
  }

  .testimonials-slider::-webkit-scrollbar-thumb {
    background-color: #50a144;
    border-radius: 6px;
  }

  /* ── Testimonial Card ───────────────────────────────── */
  .testimonial-card {
    flex: 0 0 calc(33.333% - 14px); /* 3 cards per row */
    scroll-snap-align: start;
    background-color: rgba(80, 161, 68, 0.08); /* #50A14414 approx */
    border-top: 2px solid #50a144;
    border-radius: 5px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* Stars */
  .testimonial-stars {
    display: flex;
    gap: 5px;
    color: #ffa733;
    margin-bottom: 20px;
  }

  .testimonial-stars svg {
    width: 16px;
    height: 16px;
  }

  /* Quote content */
  .testimonial-content p {
    color: #244237;
    font-family: "Poppins", sans-serif;
    font-size: 14px;
    line-height: 1.9;
    margin: 0 0 25px 0;
    flex-grow: 1;
  }

  /* Author Bio */
  .testimonial-bio {
    display: flex;
    flex-direction: column;
    margin-top: auto;
  }

  .author-name {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-weight: 700;
    font-size: 18px;
    margin: 0 0 4px 0;
  }

  .author-desc {
    color: #666666;
    font-family: "Poppins", sans-serif;
    font-size: 14px;
  }

  /* ── Tablet ≤ 1024px ───────────────────────────────── */
  @media (max-width: 1024px) {
    .testimonials-section {
      padding: 60px 0 100px 0;
    }

    /* 2 cards per row on tablet */
    .testimonial-card {
      flex: 0 0 calc(50% - 10px);
    }

    .testimonials-title {
      font-size: 40px;
    }
  }

  /* ── Mobile ≤ 767px ────────────────────────────────── */
  @media (max-width: 767px) {
    .testimonials-section {
      padding: 40px 0 30px 0;
    }

    /* 1 card per row on mobile */
    .testimonial-card {
      flex: 0 0 100%;
    }

    .testimonials-inner {
      padding: 0 25px;
    }

    .testimonials-header {
      text-align: left;
      align-items: flex-start;
    }

    .testimonials-title {
      font-size: 39px;
      line-height: 1.1;
    }
  }
</style>
