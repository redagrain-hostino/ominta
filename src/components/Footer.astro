---
const servicesLinks = [
  { href: "/ominta-domestic", label: "Ominta Domestic" },
  { href: "/ominta-commercial", label: "Ominta Commercial" },
  { href: "/femme-de-menage-tanger", label: "Femme de ménage" },
  { href: "/cleaning-company-tanger", label: "Cleaning company" },
];

export interface Props {
  ctaTitle?: string;
  ctaBtnText?: string;
  footerDesc?: string;
  legalLinksProps?: {href: string, label: string}[];
}

const defaultLegalLinks = [
  { href: "#", label: "Conditions générales" },
  { href: "#", label: "Mentions légales" },
  { href: "#", label: "Politique de confidentialité" },
  { href: "/contact", label: "Contact" },
];

const {
  ctaTitle = "Nos services vous intéressent ?",
  ctaBtnText = "Réserver maintenant",
  footerDesc = "Ominta Aus Maroc SARL, société de nettoyage basée à Tanger, propose des services de ménage et de nettoyage de première qualité pour les espaces domestiques, commerciaux, industriels et de loisirs.",
  legalLinksProps = defaultLegalLinks
} = Astro.props;
---
<!-- ── CTA pre-footer banner ──────────────────────── -->
<div class="cta-banner">
  <div class="cta-inner">

    <div class="cta-heading">
      <h2 class="cta-title">{ctaTitle}</h2>
    </div>

    <div class="cta-actions">
      <a href="tel:+212670077979" class="cta-btn cta-btn--phone">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
          <path d="M497.39 361.8l-112-48a24 24 0 0 0-28 6.9l-49.6 60.6A370.66 370.66 0 0 1 91.18 154.4l60.6-49.6a23.94 23.94 0 0 0 6.9-28l-48-112A24.16 24.16 0 0 0 83.18.16L24 8C10.72 9.44 0 20.88 0 34.32 0 261.68 250.32 512 477.68 512c13.44 0 24.88-10.72 26.32-24l7.84-59.2a24.2 24.2 0 0 0-14.45-26z"/>
        </svg>
        +212 670 07 79 79
      </a>
      <a href="/contact" class="cta-btn cta-btn--reserve">
        {ctaBtnText}
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 320 512" fill="currentColor" aria-hidden="true">
          <path d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"/>
        </svg>
      </a>
    </div>

  </div>
</div>
<footer id="site-footer" class="site-footer" role="contentinfo">

  <!-- ── Main footer body ───────────────────────────── -->
  <div class="footer-body">
    <div class="footer-inner">

      <!-- Col 1: Logo + description + social -->
      <div class="footer-brand">
        <a href="/" class="footer-logo-link">
          <img
            width="648"
            height="182"
            src="/images/logo-ominta-wh.png"
            alt="Logo Ominta"
            srcset="/images/logo-ominta-wh.png 648w,
                    /images/logo-ominta-wh-300x84.png 300w"
            sizes="(max-width:648px) 100vw, 648px"
          />
        </a>

        <p class="footer-desc">
          {footerDesc}
        </p>

        <ul class="footer-social" aria-label="Réseaux sociaux">
          <li>
            <a
              href="https://www.instagram.com/ominta_aus_maroc/"
              aria-label="Instagram"
              class="social-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <!-- Instagram SVG icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 448 512" fill="currentColor" aria-hidden="true">
                <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/>
              </svg>
              Instagram
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 2: Services links -->
      <nav class="footer-nav" aria-label="Services">
        <ul class="footer-links">
          {servicesLinks.map(link => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Col 3: Legal links -->
      <nav class="footer-nav" aria-label="Informations légales">
        <ul class="footer-links">
          {legalLinksProps.map((link: { href: string; label: string }) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

    </div>
  </div>

  <!-- ── Copyright bar ───────────────────────────────── -->
  <div class="footer-bottom">
    <div class="footer-inner">
      <p class="footer-copy">© All Rights Reserved.</p>
    </div>
  </div>

</footer>

<style>
  /* ── Footer shell: green gradient background ──────── */
  .site-footer {
    font-family: "Poppins", sans-serif;
    overflow: visible;
  }

  /* ── Centered inner wrapper (matches header 1200px) ─ */
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
  }

  /* ── Main body ────────────────────────────────────── */
  .footer-body {
    background-image: linear-gradient(126deg, #50A144 48%, #205219 100%);
    padding: 20px 0;
  }

  /* Three-column row */
  .footer-inner {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 0;
    padding-bottom: 0;
  }

  /* The body inner needs its own padding */
  .footer-body .footer-inner {
    padding-top: 60px;
    padding-bottom: 60px;
  }

  /* ── Col 1: Brand (55% desktop) ──────────────────── */
  .footer-brand {
    flex: 0 0 55%;
    width: 55%;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-logo-link img {
    width: 149px;
    height: auto;
    display: block;
    border-radius: 0;
    pointer-events: all;
  }

  .footer-desc {
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 320px;
    margin: 0;
  }

  /* Social links */
  .footer-social {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 6px;
    text-align: left;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.07);
    text-decoration: none;
    padding: 0 12px;
    line-height: 36px;
    font-family: "Poppins", sans-serif;
    font-size: 0.85rem;
    transition: background-color 0.2s ease;
  }

  .social-link:hover {
    background-color: transparent;
    color: #ffffff;
  }

  .social-link svg {
    flex-shrink: 0;
  }

  /* ── Col 2 & 3: Nav columns ──────────────────────── */
  .footer-nav {
    flex: 0 0 16%;
    width: 16%;
    display: flex;
    overflow: visible;
  }

  .footer-nav:last-child {
    flex: 0 0 23%;
    width: 23%;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer-links li:not(:last-child) {
    padding-bottom: 5px;
  }

  .footer-links li:not(:first-child) {
    margin-top: 5px;
  }

  .footer-link {
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer-link:hover {
    opacity: 0.75;
    color: #ffffff;
  }

  /* ── Copyright bar ────────────────────────────────── */
  .footer-bottom {
    background-color: #244237;
    border-top: 1px solid rgba(255, 255, 255, 0.10);
  }

  .footer-bottom .footer-inner {
    padding-top: 14px;
    padding-bottom: 14px;
    justify-content: center;
  }

  .footer-copy {
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-size: 14px;
    font-weight: 400;
    text-align: center;
    margin: 0;
  }

  /* ── Tablet ≤ 1024px ──────────────────────────────── */
  @media (max-width: 1024px) {
    .footer-brand {
      flex: 0 0 34%;
      width: 34%;
    }

    .footer-nav {
      flex: 0 0 22%;
      width: 22%;
    }

    .footer-nav:last-child {
      flex: 0 0 22%;
      width: 22%;
    }

    .footer-bottom .footer-inner {
      width: 100%;
    }
  }

  /* ── Mobile ≤ 767px ───────────────────────────────── */
  @media (max-width: 767px) {
    .footer-inner {
      padding: 0 25px;
      gap: 30px;
    }

    .footer-body .footer-inner {
      padding-top: 50px;
      padding-bottom: 40px;
    }
 
    .footer-brand {
      flex: 0 0 100%;
      width: 100%;
    }

    .footer-nav,
    .footer-nav:last-child {
      flex: 0 0 100%;
      width: 100%;
    }

    .footer-bottom .footer-inner {
      padding-top: 20px;
      padding-bottom: 20px;
      justify-content: center;
    }

    .footer-copy {
      text-align: center;
    }

    .social-link {
      padding: 0 10px;
      line-height: 38px;
    }
  }

  /* ══════════════════════════════════════════════════
     CTA PRE-FOOTER BANNER
     Source: post-27581.css — elements 3462bc2, 743da98,
     bee8309, ca59c34, 8fcd850, 3ab7e60, 5fd09f8
  ══════════════════════════════════════════════════ */

  /* Outer shell: dark green gradient, full-width */
  .cta-banner {
    background-image: linear-gradient(126deg, #205219 48%, #205219 100%);
    padding: 20px 0;
    overflow: visible;
  }

  /* Centered 1200px row – matches header/footer grid */
  .cta-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 10px;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* Left: heading (42% desktop) */
  .cta-heading {
    flex: 0 0 42%;
    width: 42%;
    display: flex;
    justify-content: center;
  }

  .cta-title {
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-size: 35px;
    font-weight: 500;
    margin: 0;
    padding: 0;
  }

  /* Right: buttons (45% desktop, flex-end) */
  .cta-actions {
    flex: 0 0 45%;
    width: 45%;
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
    gap: 10px;
  }

  /* Shared button base */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: "Poppins", sans-serif;
    font-size: 0.95rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    padding: 14px 24px;
    transition: background-color 0.2s ease, color 0.2s ease;
    align-self: center;
    box-sizing: border-box;
  }

  /* Green phone button */
  .cta-btn--phone {
    background-color: #50A144;
    color: #ffffff;
    font-weight: 600;
  }

  .cta-btn--phone:hover {
    background-color: #ffffff;
    color: #333;
  }

  /* White reserve button */
  .cta-btn--reserve {
    background-color: #ffffff;
    color: #333;
    font-weight: 500;
  }

  .cta-btn--reserve:hover {
    background-color: #ffffff;
    color: #333;
    opacity: 0.85;
  }

  .cta-btn svg {
    flex-shrink: 0;
  }

  /* ── Tablet ≤ 1024px ──────────────────────────────── */
  @media (max-width: 1024px) {
    .cta-heading {
      flex: 0 0 60%;
      width: 60%;
      justify-content: flex-start;
    }

    .cta-actions {
      flex: 0 0 35%;
      width: 35%;
      flex-direction: column;
      align-items: flex-end;
    }

    .cta-btn--phone,
    .cta-btn--reserve {
      align-self: flex-end;
    }
  }

  /* ── Mobile ≤ 767px ───────────────────────────────── */
  @media (max-width: 767px) {
    .cta-inner {
      flex-direction: column;
      align-items: center;
      gap: 20px;
      padding: 10px;
    }

    .cta-heading,
    .cta-actions {
      flex: none;
      width: 100%;
      justify-content: center;
    }
  
    .cta-title {
      font-size: 33px;
      line-height: 1.3;
      text-align: center; 
    }
 
    .cta-actions {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .cta-btn--phone,
    .cta-btn--reserve {
      width: 100%;
      justify-content: center;
      align-self: auto;
      font-size: 16px;
    }
  }
</style>