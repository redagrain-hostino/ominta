---
export interface Props {
  title?: string;
  descHtml?: string;
}

const {
  title = "Société de nettoyage à domicile",
  descHtml = `Ominta Domestic, spécialisée dans le nettoyage à domicile et la mise à disposition de
            <strong><a href="/femme-de-menage-tanger/">femmes de ménage à Tanger</a></strong>,
            transforme vos intérieurs en espaces sains, agréables et accueillants pour vous et
            vos proches. Que vous viviez en <strong>appartement, en villa ou en maison</strong>,
            nos services de ménage s'adaptent à votre mode de vie, à votre emploi du temps et à
            vos besoins uniques.`
} = Astro.props;
---

<!-- ═══════════════════════════════════════════════════════
     DOMESTIC SECTION
     Source: post-27581.css — elements d2e824a, 4e16b99,
     d630d29, ddb1394, 295e02b, 182084b, 3b9ea76, bec04f9,
     c4a9051, 425bbec, 7ad870b, fba83a8, 148d375
═══════════════════════════════════════════════════════ -->
<section id="intro" class="domestic-section">
  <div class="domestic-inner">

    <!-- ── Top row: text (left) + video (right) ────── -->
    <div class="domestic-top">

      <!-- Left: heading + logo + description (d630d29: 40% desktop) -->
      <div class="domestic-text">

        <h2 class="domestic-title">{title}</h2>

        <img
          loading="lazy"
          decoding="async"
          width="1024"
          height="292"
          src="https://www.ominta.ma/wp-content/uploads/2025/08/ominta-domestic-e1755508725634-1024x292.webp"
          alt="logo ominta domestic"
          class="domestic-logo"
          srcset="https://www.ominta.ma/wp-content/uploads/2025/08/ominta-domestic-e1755508725634-1024x292.webp 1024w,
                  https://www.ominta.ma/wp-content/uploads/2025/08/ominta-domestic-e1755508725634-768x219.webp 768w,
                  https://www.ominta.ma/wp-content/uploads/2025/08/ominta-domestic-e1755508725634-300x85.webp 300w,
                  https://www.ominta.ma/wp-content/uploads/2025/08/ominta-domestic-e1755508725634-710x202.webp 710w,
                  https://www.ominta.ma/wp-content/uploads/2025/08/ominta-domestic-e1755508725634.webp 1102w"
          sizes="(max-width:1024px) 100vw, 1024px"
        />

        <div class="domestic-desc">
          <p set:html={descHtml} />
        </div>

      </div>

      <!-- Right: YouTube embed (3b9ea76 / bec04f9) -->
      <div class="domestic-video">
        <div class="domestic-video-wrapper">
          <iframe
            loading="lazy"
            width="640"
            height="360"
            src="https://www.youtube.com/embed/zGwQyOl51QA?controls=1&rel=0&playsinline=0&cc_load_policy=0&autoplay=0"
            title="Move-Out Cleaning Service – See the Ominta Difference!"
            frameborder="0"
            allowfullscreen
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
          ></iframe>
        </div>
      </div>

    </div>

    <!-- ── Cards row: two infoboxes (c4a9051) ──────── -->
    <div class="domestic-cards">

      <!-- Card 1: Femme de ménage (425bbec / 7ad870b) -->
      <a href="/femme-de-menage-tanger/" class="service-card">
        <div class="service-card-img">
          <img
            loading="lazy"
            decoding="async"
            width="1050"
            height="608"
            src="https://www.ominta.ma/wp-content/uploads/2025/08/societe-femme-menage-tanger.jpg"
            alt="Femme de ménage à Tanger"
            srcset="https://www.ominta.ma/wp-content/uploads/2025/08/societe-femme-menage-tanger.jpg 1050w,
                    https://www.ominta.ma/wp-content/uploads/2025/08/societe-femme-menage-tanger-1024x593.jpg 1024w,
                    https://www.ominta.ma/wp-content/uploads/2025/08/societe-femme-menage-tanger-768x445.jpg 768w,
                    https://www.ominta.ma/wp-content/uploads/2025/08/societe-femme-menage-tanger-300x174.jpg 300w,
                    https://www.ominta.ma/wp-content/uploads/2025/08/societe-femme-menage-tanger-710x411.jpg 710w"
            sizes="(max-width:1050px) 100vw, 1050px"
          />
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Femme de menage</h3>
          <p>Ménage tout inclus avec produits et matériel · Femmes de ménage formées et qualifiées · Disponibles partout à Tanger (Gzenaya, Mesnana, Jbel Kebir, Rmilet, California, Malabata, Nejma) pour villas, appartements et maisons.</p>
        </div>
      </a>

      <!-- Card 2: Nettoyage canapé (fba83a8 / 148d375) -->
      <div class="service-card">
        <div class="service-card-img">
          <img
            loading="lazy"
            decoding="async"
            width="1050"
            height="608"
            src="https://www.ominta.ma/wp-content/uploads/2025/08/nettoyage-canape-tanger.jpg"
            alt="Nettoyage Canapé à Tanger"
            srcset="https://www.ominta.ma/wp-content/uploads/2025/08/nettoyage-canape-tanger.jpg 1050w,
                    https://www.ominta.ma/wp-content/uploads/2025/08/nettoyage-canape-tanger-1024x593.jpg 1024w,
                    https://www.ominta.ma/wp-content/uploads/2025/08/nettoyage-canape-tanger-768x445.jpg 768w,
                    https://www.ominta.ma/wp-content/uploads/2025/08/nettoyage-canape-tanger-300x174.jpg 300w,
                    https://www.ominta.ma/wp-content/uploads/2025/08/nettoyage-canape-tanger-710x411.jpg 710w"
            sizes="(max-width:1050px) 100vw, 1050px"
          />
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Nettoyage canapé</h3>
          <p>Intervention à domicile à Tanger pour le nettoyage à la vapeur de votre canapé en tissu · Canapés, tapis, chaises… disponibles à proximité de chez vous, dans tous les quartiers de Tanger, en urgence ou sur rendez-vous.</p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ── Outer section: d2e824a ───────────────────────────
     bg:#FFF; padding:120px; gap:30px; overflow:hidden
  ─────────────────────────────────────────────────── */
  .domestic-section {
    background-color: #ffffff;
    overflow: hidden;
  }

  /* Centered 1200px grid */
  .domestic-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 10px 120px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  /* ── Top row: 4e16b99 ─────────────────────────────────
     flex-direction:row; justify-content:space-between;
     padding-bottom:30px
  ─────────────────────────────────────────────────── */
  .domestic-top {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: stretch;
    padding-bottom: 30px;
    gap: 30px;
    overflow: visible;
  }

  /* ── Left text col: d630d29 ───────────────────────────
     width:40% desktop; align-self:center
  ─────────────────────────────────────────────────── */
  .domestic-text {
    flex: 0 0 40%;
    width: 40%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    align-self: center;
    margin-right: 50px;
  }

  /* Heading: ddb1394 — color:#000; size:50px; weight:700 */
  .domestic-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-size: 50px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
  }

  /* Logo image: 295e02b — width:52%; text-align:left */
  .domestic-logo {
    width: 52%;
    height: auto;
    display: block;
    pointer-events: all;
  }

  /* Description: 182084b — color:#4B4848; size:16px */
  .domestic-desc p {
    color: #4B4848;
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    line-height: 1.7;
    margin: 0;
  }

  .domestic-desc :global(a) {
    color: #4B4848;
    font-weight: inherit;
  }

  .domestic-desc :global(a:hover) {
    color: #50A144;
  }

  /* ── Video col: 3b9ea76 / bec04f9 ────────────────────
     fills remaining space; responsive 16:9 aspect ratio
  ─────────────────────────────────────────────────── */
  .domestic-video {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  /* Responsive 16:9 wrapper */
  .domestic-video-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
  }

  .domestic-video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── Cards row: c4a9051 ─────────────────────────────── */
  .domestic-cards {
    display: flex;
    flex-direction: row;
    gap: 30px;
  }

  /* ── Individual card: 7ad870b / 148d375 ──────────────
     bg:#fff; border:none; 
     title: color:#000; weight:600
     p: margin-right:100px (desktop)
  ─────────────────────────────────────────────────── */
  .service-card {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    background-color: #ffffff;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .service-card-img {
    overflow: hidden;
  }

  .service-card-img img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.3s ease;
  }

  a.service-card:hover .service-card-img img {
    transform: scale(1.03);
  }

  .service-card-body {
    padding: 20px 0 0;
  }

  .service-card-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    margin: 0 0 10px 0;
  }

  .service-card-body p {
    color: #4B4848;
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    line-height: 1.6;
    margin: 0 100px 0 0; /* 7ad870b: margin-right:100px */
  }

  /* ── Tablet ≤ 1024px ─────────────────────────────── */
  @media (max-width: 1024px) {
    .domestic-top {
      padding: 10px 20px;
      flex-direction: column;
    }

    .domestic-text {
      flex: none;
      width: 100%;
      max-width: 350px; /* 182084b: max-width:350px on tablet */
      margin-right: 0;
      align-self: auto;
    }

    .domestic-title {
      text-align: center;
    }

    .domestic-video {
      flex: none;
      width: 100%;
    }

    .service-card-body p {
      margin-right: 0;
    }

    .domestic-cards {
      gap: 20px;
    }
  }

  /* ── Mobile ≤ 767px ──────────────────────────────── */
  @media (max-width: 767px) {
    .domestic-inner {
      padding: 40px 25px 40px;
      gap: 20px;
    }

    .domestic-top {
      padding: 0;
      gap: 12px;
    }

    .domestic-text {
      max-width: 100%;
    }

    /* ddb1394 mobile: font-size:57px; line-height:0.9em */
    .domestic-title {
      font-size: 57px;
      line-height: 0.9;
      text-align: left;
    }

    .domestic-cards {
      flex-direction: column;
      gap: 20px;
    }

    .service-card-body p {
      margin-right: 0;
    }
  }
</style>
