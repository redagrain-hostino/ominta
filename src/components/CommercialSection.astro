<!-- ═══════════════════════════════════════════════════════
     COMMERCIAL SECTION
     Same layout pattern as DomesticSection:
     top row (text left + video right) + cards row below
═══════════════════════════════════════════════════════ -->
<section class="commercial-section">
  <div class="commercial-inner">

    <!-- ── Top row: text (left) + video (right) ────── -->
    <div class="commercial-top">

      <!-- Left: heading + logo + description -->
      <div class="commercial-text">

        <h2 class="commercial-title">Société de nettoyage professionnel</h2>

        <img
          loading="lazy"
          decoding="async"
          width="1001"
          height="322"
          src="/images/ominta-commercial.jpg"
          alt="Ominta Commercial"
          class="commercial-logo"
          srcset="/images/ominta-commercial.jpg 1001w,
                  /images/ominta-commercial-768x247.jpg 768w,
                  /images/ominta-commercial-300x97.jpg 300w,
                  /images/ominta-commercial-710x228.jpg 710w"
          sizes="(max-width:1001px) 100vw, 1001px"
        />

        <div class="commercial-desc">
          <p>
            Chez Ominta Commercial, nous faisons de vos espaces de travail des environnements
            impeccables, sûrs et sains, adaptés à toutes les entreprises, quelle que soit leur
            taille ou leur secteur d'activité. Qu'il s'agisse de <strong>bureaux</strong>, de
            <strong>chaînes de magasins</strong>, <strong>d'hôtels</strong>,
            <strong>d'usines</strong>, d'entrepôts ou d'institutions, nos solutions de nettoyage
            sur mesure garantissent la continuité de vos activités tout en valorisant l'image de
            votre organisation.
          </p>
        </div>

      </div>

      <!-- Right: YouTube embed -->
      <div class="commercial-video">
        <div class="commercial-video-wrapper">
          <iframe
            loading="lazy"
            width="640"
            height="360"
            src="https://www.youtube.com/embed/HKyv1vGcyi4?controls=1&rel=0&playsinline=0&cc_load_policy=0&autoplay=0"
            title="Société de nettoyage professionnel à Tanger - Ominta"
            frameborder="0"
            allowfullscreen
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
          ></iframe>
        </div>
      </div>

    </div>

    <!-- ── Cards row ──────────────────────────────── -->
    <div class="commercial-cards">

      <!-- Card 1: Nettoyage Industriel -->
      <div class="service-card">
        <div class="service-card-img">
          <img
            loading="lazy"
            decoding="async"
            width="1050"
            height="608"
            src="/images/nettoyage-industriel-tanger.jpg"
            alt="Société de Nettoyage industriel Tanger"
            srcset="/images/nettoyage-industriel-tanger.jpg 1050w,
                    /images/nettoyage-industriel-tanger-1024x593.jpg 1024w,
                    /images/nettoyage-industriel-tanger-768x445.jpg 768w,
                    /images/nettoyage-industriel-tanger-300x174.jpg 300w,
                    /images/nettoyage-industriel-tanger-710x411.jpg 710w"
            sizes="(max-width:1050px) 100vw, 1050px"
          />
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Nettoyage Industriel</h3>
          <p>Nous intervenons dans toutes les zones industrielles de Tanger (Tanger Free Zone, TAC Gzenaya, Mgougha, Tanger Tec…) pour assurer le nettoyage professionnel de vos usines, entrepôts et sites de production avec efficacité et sécurité.</p>
        </div>
      </div>

      <!-- Card 2: Nettoyage de bureaux -->
      <div class="service-card">
        <div class="service-card-img">
          <img
            loading="lazy"
            decoding="async"
            width="1050"
            height="608"
            src="/images/nettoyage-bureau-tanger.jpg"
            alt="Nettoyage de bureau à Tanger"
            srcset="/images/nettoyage-bureau-tanger.jpg 1050w,
                    /images/nettoyage-bureau-tanger-1024x593.jpg 1024w,
                    /images/nettoyage-bureau-tanger-768x445.jpg 768w,
                    /images/nettoyage-bureau-tanger-300x174.jpg 300w,
                    /images/nettoyage-bureau-tanger-710x411.jpg 710w"
            sizes="(max-width:1050px) 100vw, 1050px"
          />
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Nettoyage de bureaux</h3>
          <p>Service de nettoyage de bureaux à Tanger, zones franches, centres d'affaires et showrooms : entretien quotidien, sols et vitres, nettoyage des sanitaires, organisation des espaces, postes de travail et ordinateurs.</p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ── Outer section (mirrors DomesticSection exactly) ─ */
  .commercial-section {
     overflow: hidden;
  }

  .commercial-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 10px 120px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  /* ── Top row ─────────────────────────────────────────── */
  .commercial-top {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: stretch;
    padding-bottom: 30px;
    gap: 30px;
    overflow: visible;
  }

  /* Left: 40% desktop; align-self:center */
  .commercial-text {
    flex: 0 0 40%;
    width: 40%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    align-self: center;
    margin-right: 50px;
  }

  /* Heading: color:#000; 50px; weight:700 */
  .commercial-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-size: 50px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
  }

  /* Logo: width:52% */
  .commercial-logo {
    width: 52%;
    height: auto;
    display: block;
    pointer-events: all;
  }

  /* Description: color:#4B4848; size:16px */
  .commercial-desc p {
    color: #4B4848;
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    line-height: 1.7;
    margin: 0;
  }

  /* Video: fills remaining space; 16:9 */
  .commercial-video {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .commercial-video-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }

  .commercial-video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── Cards row ─────────────────────────────────────── */
  .commercial-cards {
    display: flex;
    flex-direction: row;
    gap: 30px;
  }

  .service-card {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    background-color: #ffffff;
    text-decoration: none;
    color: inherit;
  }

  .service-card-img {
    overflow: hidden;
  }

  .service-card-img img {
    display: block;
    width: 100%;
    height: auto;
  }

  .service-card-body {
    padding: 20px 0 0;
  }

  .service-card-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    margin: 0 0 10px 0;
  }

  .service-card-body p {
    color: #4B4848;
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    line-height: 1.6;
    margin: 0 100px 0 0;
  }

  /* ── Tablet ≤ 1024px ───────────────────────────────── */
  @media (max-width: 1024px) {
    .commercial-top {
      padding: 10px 20px;
      flex-direction: column;
    }

    .commercial-text {
      flex: none;
      width: 100%;
      max-width: 350px;
      margin-right: 0;
      align-self: auto;
    }

    .commercial-title {
      text-align: center;
    }

    .commercial-video {
      flex: none;
      width: 100%;
    }

    .service-card-body p {
      margin-right: 0;
    }

    .commercial-cards {
      gap: 20px;
    }
  }

  /* ── Mobile ≤ 767px ────────────────────────────────── */
  @media (max-width: 767px) {
    .commercial-inner {
      padding: 40px 25px 40px;
      gap: 20px;
    }

    .commercial-top {
      padding: 0;
      gap: 12px;
    }

    .commercial-text {
      max-width: 100%;
    }

    .commercial-title {
      font-size: 36px;
      line-height: 1.1;
      text-align: left;
    }

    .commercial-cards {
      flex-direction: column;
      gap: 20px;
    }

    .service-card-body p {
      margin-right: 0;
    }
  }
</style>
