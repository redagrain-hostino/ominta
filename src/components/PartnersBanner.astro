---
export interface Props {
  background?: string;
}

const { background = "linear-gradient(126deg, #50A144 48%, #205219 100%)" } = Astro.props;
---

<div class="partners-banner" style={`background-image: ${background};`}>
  <img
    decoding="async"
    width="1024"
    height="57"
    src="/images/partenaires-nettoyage-tanger-1024x57.png"
    alt="Partenaires de notre société de nettoyage Tanger"
    srcset="/images/partenaires-nettoyage-tanger-1024x57.png 1024w,
            /images/partenaires-nettoyage-tanger-768x43.png 768w,
            /images/partenaires-nettoyage-tanger-300x17.png 300w,
            /images/partenaires-nettoyage-tanger.png 1623w"
    sizes="(max-width:1024px) 100vw, 1024px"
  />
</div>

<style>
  /* ═══════════════════════════════════════════════════
     PARTNERS BANNER
  ═══════════════════════════════════════════════════ */
  .partners-banner {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 0;
  }

  .partners-banner img {
    width: 30%;
    height: auto;
    pointer-events: none;
  }

  /* ═══════════════════════════════════════════════════
     RESPONSIVE – tablet ≤ 1024px
  ═══════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .partners-banner img {
      width: 85%;
    }
  }

  /* ═══════════════════════════════════════════════════
     RESPONSIVE – mobile ≤ 767px
  ═══════════════════════════════════════════════════ */
  @media (max-width: 767px) {
    .partners-banner img {
      width: 85%;
    }
  }
</style>
