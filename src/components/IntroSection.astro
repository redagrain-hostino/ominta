---
export interface Props {
  title?: string;
  paragraphs?: string[];
  ctaText?: string;
}

const defaultParagraphs = [
  "Ominta, société de nettoyage à Tanger, met à votre service son expertise pour tous vos besoins de propreté, aussi bien à domicile que dans vos locaux professionnels.",
  "Avec <a href=\"/ominta-domestic\"><strong>Ominta Domestic</strong></a>, nous vous proposons un service de ménage fiable et rigoureux pour le nettoyage de votre maison, appartement ou villa.",
  "En parallèle, <a href=\"/ominta-commercial\"><strong>Ominta Commercial</strong></a> répond aux besoins des entreprises et professionnels de Tanger. Nous assurons le nettoyage et l'entretien de bureaux, hôtels, showrooms, commerces et usines, en offrant des solutions sur mesure qui s'adaptent à chaque secteur d'activité.",
  "Appelez dès maintenant le (+212)&nbsp;670-077-979 et confiez vos besoins de nettoyage à une société spécialisée, disponible et à l'écoute de vos attentes."
];

const {
  title = "Société de Nettoyage à Tanger",
  paragraphs = defaultParagraphs,
  ctaText = "Réserver maintenant"
} = Astro.props;
---

<!-- ═══════════════════════════════════════════════════════
     INTRO SECTION: text left / image right
     Source: post-27581.css — elements 2c64171, 874e8d3,
     56ba25f, 930abeb, d9b35e1, 8c7c551
═══════════════════════════════════════════════════════ -->
<section class="intro-section">
  <div class="intro-inner">

    <!-- Left: heading + body + CTA -->
    <div class="intro-left">

      <div class="intro-text">
        <h2 class="intro-title">{title}</h2>

        <div class="intro-desc">
          {paragraphs.map(p => <p set:html={p} />)}
        </div>
      </div>

      <!-- CTA button (hidden on tablet & mobile per original) -->
      <div class="intro-cta">
        <a href="/contact" class="intro-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
            <path d="M502.3 190.8c3.9-3.1 9.7-.2 9.7 4.7V400c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V195.6c0-5 5.7-7.8 9.7-4.7 22.4 17.4 52.1 39.5 154.1 113.6 21.1 15.4 56.7 47.8 92.2 47.6 35.7.3 72-32.8 92.3-47.6 102-74.1 131.6-96.3 154-113.7zM256 320c23.2.4 56.6-29.2 73.4-41.4 132.7-96.3 142.8-104.7 173.4-128.7 5.8-4.5 9.2-11.5 9.2-18.9v-19c0-26.5-21.5-48-48-48H48C21.5 64 0 85.5 0 112v19c0 7.4 3.4 14.3 9.2 18.9 30.6 23.9 40.7 32.4 173.4 128.7 16.8 12.2 50.2 41.8 73.4 41.4z"/>
          </svg>
          <span>{ctaText}</span>
        </a>
      </div>

    </div>

    <!-- Right: service image -->
    <div class="intro-right">
      <img
        loading="lazy"
        decoding="async"
        width="1024"
        height="957"
        src="/images/societe-nettoyage-tanger-1024x957.jpg"
        alt="Société de Nettoyage disponible à Tanger"
        srcset="/images/societe-nettoyage-tanger-1024x957.jpg 1024w,
                /images/societe-nettoyage-tanger-768x717.jpg 768w,
                /images/societe-nettoyage-tanger-300x280.jpg 300w,
                /images/societe-nettoyage-tanger-710x663.jpg 710w,
                /images/societe-nettoyage-tanger.jpg 1200w"
        sizes="(max-width:1024px) 100vw, 1024px"
      />
    </div>

  </div>
</section>

<style>
  /* ── Outer section ────────────────────────────────────
     2c64171: row layout, padding-top:120px, no gap
  ─────────────────────────────────────────────────── */
  .intro-section {
    overflow: visible;
  }

  /* Centered 1200px grid – matches header */
  .intro-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 10px 0;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 0;
    flex-wrap: wrap;
  }

  /* ── LEFT column: 874e8d3 / 56ba25f ──────────────────
     flex-direction:column; margin-right:50px on widget
  ─────────────────────────────────────────────────── */
  .intro-left {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: visible;
  }

  .intro-text {
    margin: 0 50px 20px 0;
  }

  /* Heading: 56ba25f — color:#000; font-size:50px; weight:700 */
  .intro-title {
    color: #000000;
    font-family: "Poppins", sans-serif;
    font-size: 45px;
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 20px 0;
  }

  /* Body paragraphs: color:#4B4848; size:16px */
  .intro-desc p {
    color: #4B4848;
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    line-height: 1.7;
    margin: 0 0 14px 0;
  }

  .intro-desc :global(a) {
    color: #4B4848;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .intro-desc :global(a:hover) {
    color: #50A144;
  }

  /* ── CTA button: 930abeb
     gradient(85deg, #50A144 35%, #28751D); padding:17px 50px
  ─────────────────────────────────────────────────── */
  .intro-cta {
    margin-top: 4px;
  }

  .intro-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-image: linear-gradient(85deg, #50A144 35%, #28751D 100%);
    color: #ffffff;
    padding: 17px 50px;
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .intro-btn:hover {
    opacity: 0.88;
    color: #ffffff;
  }

  .intro-btn svg {
    flex-shrink: 0;
  }

  /* ── RIGHT column: d9b35e1 / 8c7c551 ────────────────
     flex-direction:column; image flush to bottom
  ─────────────────────────────────────────────────── */
  .intro-right {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: visible;
  }

  .intro-right img {
    display: block;
    width: 100%;
    height: auto;
    pointer-events: all;
  }

  /* ── Tablet ≤ 1024px ─────────────────────────────── */
  @media (max-width: 1024px) {
    .intro-inner {
      flex-direction: column;
      padding-top: 60px;
      gap: 30px;
    }

    .intro-text {
      margin-right: 0;
    }

    .intro-title {
      text-align: center;
    }

    .intro-cta {
      display: none; /* hidden on tablet per original 930abeb: elementor-hidden-tablet */
    }
  }

  /* ── Mobile ≤ 767px ──────────────────────────────── */
  @media (max-width: 767px) {
    .intro-inner {
      padding: 60px 25px 0;
    }

    .intro-text {
      margin-right: 0;
    }

    /* 56ba25f mobile: font-size:57px; line-height:0.9em */
    .intro-title {
      font-size: 36px;
      line-height: 1.1;
      text-align: left;
    }

    .intro-cta {
      display: none; /* hidden on mobile per original 930abeb: elementor-hidden-mobile */
    }
  }
</style>
